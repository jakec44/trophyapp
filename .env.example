# Copy this file to .env and fill in your keys

# Supabase (required)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# LAN dev: your PC IP so phone can connect (optional; create .env.local instead)
# REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.151

# Optional: Enhance (fal.ai) + AI fish detection (species, weight, length)
# EXPO_PUBLIC_FAL_KEY=

# RevenueCat (optional — set for Pro subscriptions)
# EXPO_PUBLIC_REVENUECAT_API_KEY=
