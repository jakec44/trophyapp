{
  "expo": {
    "name": "Snagged",
    "slug": "snagged",
    "scheme": "snagged",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/loading-trophy.png",
      "resizeMode": "contain",
      "backgroundColor": "#020b14"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.jakec44.snagged",
      "infoPlist": {
        "NSCameraUsageDescription": "Snagged needs camera access to take photos of your catches.",
        "NSPhotoLibraryUsageDescription": "Snagged needs access to your Apple Photos to upload images of your catches.",
        "NSLocationWhenInUseUsageDescription": "Snagged uses your location to show local tournaments near you.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#020b14"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.snagged"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-splash-screen",
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Snagged needs access to your Apple Photos to upload images of your catches.",
          "cameraPermission": "Snagged needs camera access."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "12b4b307-11e3-4d98-b7df-2d98d0f05d4b"
      }
    }
  }
}
